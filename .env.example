# =============================================================================
# identark-sdk — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env — only .env.example belongs in version control.
# =============================================================================

# -----------------------------------------------------------------------------
# SDK — ControlPlaneGateway configuration
# Required when using ControlPlaneGateway outside a sandbox
# -----------------------------------------------------------------------------
IDENTARK_API_KEY=your-identark-api-key-here
IDENTARK_CONTROL_PLANE_URL=https://api.identark.io/v1

# Inside a IdentArk sandbox these are injected automatically:
IDENTARK_SESSION_TOKEN=
IDENTARK_SESSION_ID=

# -----------------------------------------------------------------------------
# LLM Providers — DirectGateway (local development only)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# identark-cloud (cloud control plane local dev)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/identark_dev
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key

# HashiCorp Vault (credential storage)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token          # dev only — never use root token in production

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
LOGFIRE_TOKEN=

# -----------------------------------------------------------------------------
# CI / GitHub Actions
# These are set as GitHub repository secrets — never hardcode them
# PYPI_API_TOKEN → set in GitHub secrets as PYPI_API_TOKEN
# CODECOV_TOKEN  → set in GitHub secrets as CODECOV_TOKEN
# -----------------------------------------------------------------------------
